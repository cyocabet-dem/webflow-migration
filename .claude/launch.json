{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nuxt-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "app"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "nuxt-dev-mock",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:mock", "--prefix", "app"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
