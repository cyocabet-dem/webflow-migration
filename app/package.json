{
  "name": "dematerialized-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "dev:mock": "NUXT_PUBLIC_DEV_MOCK_AUTH=1 DEV_API_TARGET=http://localhost:8000 nuxt dev",
    "build:mobile": "NUXT_MOBILE=1 nuxt generate",
    "mobile:sync": "npm run build:mobile && node scripts/prune-mobile-bundle.mjs && cap sync",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:assets": "capacitor-assets generate --assetPath resources --ios --android"
  },
  "dependencies": {
    "@auth0/auth0-spa-js": "^2.1.3",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@nuxtjs/i18n": "^9.5.0",
    "nuxt": "^3.17.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.6": true
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1"
  }
}
